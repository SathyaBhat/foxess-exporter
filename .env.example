# FoxESS Exporter — environment configuration
# Copy this file to .env and fill in your values.
# All FOXESS_* variables map directly to config.yaml keys (see config.yaml.example).

# ── FoxESS Cloud ─────────────────────────────────────────────────────────────

# Your API key from FoxESS Cloud → Personal Centre → API Management.
FOXESS_FOXESS_API_KEY=your-foxess-api-key-here

# Serial number of your inverter.
# Leave empty to auto-discover the first inverter on the account.
# If you have more than one inverter, set this explicitly.
FOXESS_FOXESS_DEVICE_SN=

# ── InfluxDB v3 ───────────────────────────────────────────────────────────────

# Host of your existing InfluxDB v3 instance.
# Use the Docker service name if InfluxDB is on the same dokploy-network,
# e.g. http://influxdb:8086.  Use a full URL for a remote or Cloud instance.
FOXESS_INFLUXDB_HOST=http://influxdb:8086

# InfluxDB auth token — needs write access to the database below.
FOXESS_INFLUXDB_TOKEN=your-influxdb-token-here

# Database (InfluxDB v3 bucket) to write into.  Created automatically if the
# token has the required permissions.
FOXESS_INFLUXDB_DATABASE=foxess

# ── Polling intervals ─────────────────────────────────────────────────────────

# How often to hit the real-time endpoint.
# FoxESS enforces 1 req/sec and 1440 calls/day per inverter.
# 60s = exactly 1440 calls/day — the safe maximum.
# Use 120s if you share the budget with Home Assistant or other integrations.
FOXESS_EXPORTER_REALTIME_INTERVAL=60s

# How often to refresh the daily energy-total report.
FOXESS_EXPORTER_REPORT_INTERVAL=5m

# ── Backfill ──────────────────────────────────────────────────────────────────

# Fill gaps in InfluxDB on startup using the FoxESS history endpoint.
# Each 24h window costs 1 API call; a 7-day backfill = 7 extra calls at boot.
FOXESS_EXPORTER_BACKFILL_ENABLED=true

# How far back to look when backfilling (Go duration string).
# FoxESS history is typically available for ~30 days.
FOXESS_EXPORTER_BACKFILL_MAX_AGE=168h

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error
FOXESS_LOG_LEVEL=info
